---
import { site } from '../config/site';
---
<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <img src={site.logo} alt="logo" />
      <div>
        <div style="font-family:var(--font-display);font-size:1.1rem;">{site.siteTitle}</div>
        <div class="footer__meta">{site.subtitle}</div>
      </div>
    </div>
    <div class="footer__social">
      {site.social.map(s => (
        <a class="icon-btn" href={s.url} target="_blank" rel="noopener" aria-label={s.name}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
            {s.icon === 'github' && <path d="M9 19c-4 1.4-4-2.5-6-3m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6.2a4.8 4.8 0 0 0-1.3-3.3 4.5 4.5 0 0 0-.1-3.3s-1-.3-3.4 1.3a11.7 11.7 0 0 0-6.2 0C6.7 2.4 5.7 2.7 5.7 2.7a4.5 4.5 0 0 0-.1 3.3A4.8 4.8 0 0 0 4.3 9.3c0 4.8 2.7 5.9 5.5 6.2-.6.6-.6 1.2-.5 2V21" />}
            {s.icon === 'mail' && <><rect x="3" y="5" width="18" height="14" /><path d="m3 7 9 6 9-6" /></>}
            {s.icon === 'rss' && <><path d="M4 11a9 9 0 0 1 9 9M4 4a16 16 0 0 1 16 16" /><circle cx="5" cy="19" r="1.5" fill="currentColor" /></>}
          </svg>
        </a>
      ))}
    </div>
  </div>
</footer>
