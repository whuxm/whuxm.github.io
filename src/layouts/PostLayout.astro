---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: string;
  readingTime: number;
  wordCount: number;
  slug: string;
}
const { title, date, readingTime, wordCount, slug } = Astro.props;
---
<BaseLayout title={`${title} · RS NOTES`}>
  <article class="note-detail" data-slug={slug}>
    <div class="container">
      <a class="note-back" href="/notes">← Back to Notes</a>
      <div class="note-detail__header">
        <span class="eyebrow">{date}</span>
        <h1 class="note-detail__title">{title}</h1>
        <div class="note-detail__meta">
          <span>📅 {date}</span>
          <span class="note-views" data-id={slug}>👁 0 views</span>
          <span>⏱ 约 {readingTime} 分钟阅读</span>
          <span>📝 {wordCount} 字</span>
        </div>
      </div>
      <div class="note-detail__body">
        <slot />
      </div>
    </div>
  </article>

  <div class="lightbox" id="noteLightbox">
    <span class="lightbox__close" id="noteLightboxClose">×</span>
    <img id="noteLightboxImg" src="" alt="" />
    <div class="lightbox__caption" id="noteLightboxCaption"></div>
  </div>
</BaseLayout>

<script>
  import { updateViews } from '../scripts/readingStats';

  const article = document.querySelector<HTMLElement>('.note-detail[data-slug]');
  const slug = article?.dataset.slug;
  if (slug) {
    const el = document.querySelector<HTMLElement>(`.note-views[data-id="${slug}"]`);
    updateViews(slug).then(count => {
      if (el) el.textContent = `👁 ${count} views`;
    });
  }

  /* ---------- 图片灯箱 ---------- */
  const lb = document.getElementById('noteLightbox');
  const lbImg = document.getElementById('noteLightboxImg') as HTMLImageElement | null;
  const lbCap = document.getElementById('noteLightboxCaption');
  const lbClose = document.getElementById('noteLightboxClose');

  const closeLb = () => {
    lb?.classList.remove('is-open');
    document.body.style.overflow = '';
  };
  const openLb = (src: string, alt: string) => {
    if (!lb || !lbImg) return;
    lbImg.src = src;
    lbImg.alt = alt;
    if (lbCap) lbCap.textContent = alt;
    lb.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  };

  document.querySelectorAll<HTMLImageElement>('.note-detail__content img').forEach(img => {
    img.addEventListener('click', () => openLb(img.currentSrc || img.src, img.alt));
  });
  lbClose?.addEventListener('click', closeLb);
  lb?.addEventListener('click', (e) => { if (e.target === lb) closeLb(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLb(); });
</script>
